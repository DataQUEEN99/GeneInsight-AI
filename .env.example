# GeneInsight AI Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=GeneInsight AI
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://geneinsight:geneinsight_password@db:5432/geneinsight
DATABASE_ECHO=false

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# RAG Configuration
CHROMA_DB_PATH=./chroma_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=100
MIN_SIMILARITY_SCORE=0.6
TOP_K_RESULTS=5

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=GeneInsight AI
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=info

# File Upload
MAX_UPLOAD_SIZE_MB=500
ALLOWED_FILE_EXTENSIONS=vcf,csv,tsv

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password_change_in_production

# Knowledge Base Ingestion
INGEST_ON_STARTUP=true
INGESTION_BATCH_SIZE=100
